[
  {
    "type": "function",
    "function": {
      "name": "call_meituan_skill",
      "description": "调用美团本地生活 Skill，搜索餐厅、酒店、景点、门票、团购、附近吃喝玩乐等资源。适用于用户提出酒店预订、餐厅推荐、团购优惠、景点门票、周边游、吃喝玩乐、下单前资源搜索等需求。",
      "parameters": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "string",
            "description": "用户意图类型",
            "enum": [
              "restaurant_search",
              "hotel_search",
              "ticket_search",
              "group_buy_query",
              "nearby_search",
              "booking_query"
            ]
          },
          "city": {
            "type": "string",
            "description": "城市名称，例如上海、杭州、北京、深圳、新加坡"
          },
          "keyword": {
            "type": "string",
            "description": "搜索关键词，例如西湖酒店、杭帮菜、外滩餐厅、亲子乐园、火锅、日料、景点门票"
          },
          "location": {
            "type": "string",
            "description": "用户当前位置或商圈，例如西湖附近、外滩附近、人民广场附近、东海岸附近"
          },
          "user_lat": {
            "type": "number",
            "description": "用户纬度，可选"
          },
          "user_lng": {
            "type": "number",
            "description": "用户经度，可选"
          },
          "filters": {
            "type": "object",
            "description": "筛选条件",
            "properties": {
              "rating": {
                "type": "number",
                "description": "最低评分，例如4.5"
              },
              "price_low": {
                "type": "number",
                "description": "最低价格"
              },
              "price_high": {
                "type": "number",
                "description": "最高价格"
              },
              "distance_radius": {
                "type": "number",
                "description": "搜索半径，单位米，例如3000"
              },
              "sort_by": {
                "type": "string",
                "description": "排序方式",
                "enum": [
                  "distance",
                  "rating",
                  "price",
                  "default"
                ]
              },
              "cuisine": {
                "type": "string",
                "description": "菜系，例如杭帮菜、川菜、日料、火锅、烧烤、西餐"
              },
              "tags": {
                "type": "array",
                "description": "标签，例如亲子、情侣、出片、安静、排队少、性价比",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "limit": {
            "type": "integer",
            "description": "返回数量，默认5",
            "default": 5
          }
        },
        "required": [
          "intent",
          "city"
        ]
      }
    }
  }
]